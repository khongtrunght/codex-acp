{
  "name": "codex-acp-bridge",
  "version": "1.0.0",
  "description": "ACP bridge for the Codex app-server. Run Codex from any ACP-compatible client.",
  "license": "Apache-2.0",
  "author": "khongtrunght",
  "homepage": "https://github.com/khongtrunght/codex-acp#readme",
  "bugs": {
    "url": "https://github.com/khongtrunght/codex-acp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khongtrunght/codex-acp.git"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "codex",
    "openai",
    "zed",
    "ide",
    "cli"
  ],
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "module": "dist/lib.js",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "bin": {
    "codex-acp-bridge": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/**/*.test.*",
    "!dist/**/*.integration.*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "test": "bun test",
    "test:integration": "RUN_INTEGRATION_TESTS=true bun test src/agent.integration.test.ts",
    "smoke": "node scripts/smoke-acp.mjs",
    "build": "node scripts/build-npm.mjs",
    "prepublishOnly": "bun run check && bun run test && bun run build",
    "build:binary": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/codex-acp-bridge",
    "build:binary:darwin-arm64": "bun build --compile --minify --sourcemap --target bun-darwin-arm64 src/index.ts --outfile dist/codex-acp-bridge-darwin-arm64",
    "build:binary:darwin-x64": "bun build --compile --minify --sourcemap --target bun-darwin-x64 src/index.ts --outfile dist/codex-acp-bridge-darwin-x64",
    "build:binary:linux-x64": "bun build --compile --minify --sourcemap --target bun-linux-x64 src/index.ts --outfile dist/codex-acp-bridge-linux-x64",
    "build:binary:linux-arm64": "bun build --compile --minify --sourcemap --target bun-linux-arm64 src/index.ts --outfile dist/codex-acp-bridge-linux-arm64",
    "build:binary:windows-x64": "bun build --compile --minify --sourcemap --target bun-windows-x64 src/index.ts --outfile dist/codex-acp-bridge-windows-x64.exe",
    "build:binary:all": "bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:windows-x64"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
